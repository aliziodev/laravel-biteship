{
    "name": "aliziodev/laravel-biteship",
    "description": "Laravel package for Biteship shipping aggregator API integration",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alizio",
            "email": "aliziodev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Aliziodev\\Biteship\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aliziodev\\Biteship\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aliziodev\\Biteship\\BiteshipServiceProvider"
            ],
            "aliases": {
                "Biteship": "Aliziodev\\Biteship\\Facades\\Biteship"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
